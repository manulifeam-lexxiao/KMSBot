{
  "name": "kmsbot",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,yellow\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "uvicorn kms_bot.main:app --reload --host 127.0.0.1 --port 8000 --app-dir backend/src",
    "dev:frontend": "cd frontend && npm run dev",
    "lint": "cd frontend && npm run lint",
    "format": "cd frontend && npm run format",
    "format:check": "cd frontend && npm run format:check",
    "test": "cd frontend && npm run test",
    "test:watch": "cd frontend && npm run test:watch"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
