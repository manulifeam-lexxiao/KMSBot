{
  "name": "kmsbot",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,yellow\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "uvicorn kms_bot.main:app --reload --host 127.0.0.1 --port 8000 --app-dir backend/src",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
